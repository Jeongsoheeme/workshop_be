# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/workshop

# 테스트는 운영 DB 를 건드리지 않도록 별도 DB(<원본>_test)에 격리 실행된다.
# 기본 이름은 위 DB 이름 + "_test" 이며, 아래로 재정의할 수 있다.
# TEST_DATABASE_NAME=workshop_test

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# App
APP_NAME=Workshop API
DEBUG=True
